{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/marketing/**",
              "ui_kits/landing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Manrope|Onest))/i]",
        "message": "Font not provided by the design system. Available: Manrope, Onest."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|href|type|disabled|className|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, href, type, disabled, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|onNavy)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'onNavy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|value|href|className|style|key|ref|className|style|children)$/]",
        "message": "<ContactCard> doesn't accept that prop. Declared props: icon, label, value, href, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DashedCallout'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|shape|tone|children|className|style|key|ref|className|style|children)$/]",
        "message": "<DashedCallout> doesn't accept that prop. Declared props: icon, shape, tone, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DashedCallout'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:pill|circle)$/]",
        "message": "<DashedCallout> shape must be one of 'pill' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DashedCallout'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|blue)$/]",
        "message": "<DashedCallout> tone must be one of 'light' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCheck'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|className|style|key|ref|className|style|children)$/]",
        "message": "<FeatureCheck> doesn't accept that prop. Declared props: children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|showWordmark|wordmarkColor|className|style|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: size, showWordmark, wordmarkColor, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|lead|align|tone|className|style|key|ref|className|style|children)$/]",
        "message": "<SectionHeading> doesn't accept that prop. Declared props: eyebrow, title, lead, align, tone, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:center|left)$/]",
        "message": "<SectionHeading> align must be one of 'center' | 'left'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<SectionHeading> tone must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ServiceBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|children|badgeSize|className|style|key|ref|className|style|children)$/]",
        "message": "<ServiceBadge> doesn't accept that prop. Declared props: icon, title, children, badgeSize, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WaveDivider'] > JSXAttribute > JSXIdentifier[name!=/^(?:fill|flip|height|className|style|key|ref|className|style|children)$/]",
        "message": "<WaveDivider> doesn't accept that prop. Declared props: fill, flip, height, className, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
